@page 
@model IndexModel
<!DOCTYPE html>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<div class="container mt-5">
    <h1 class="mb-4"><i class="fas fa-link text-primary"></i> URL Shortener</h1>
    
    <div class="card mb-4 shadow">
        <div class="card-body">
            <form method="post">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-globe"></i></span>
                    <input asp-for="OriginalUrl" class="form-control" placeholder="https://example.com/very/long/url">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-magic"></i> Сократить</button>
                </div>
                <div asp-validation-summary="All" class="text-danger mt-2"></div>
            </form>
            
            @if (!string.IsNullOrEmpty(Model.ShortUrl))
            {
                <div class="mt-3 p-3 bg-success text-white rounded">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-check-circle me-2"></i>
                        <strong>Готово!</strong>
                        <span class="ms-2 flex-grow-1">@Model.ShortUrl</span>
                        <button class="btn btn-sm btn-light" onclick="copyToClipboard('@Model.ShortUrl')">
                            <i class="fas fa-copy"></i> Копировать
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    <h3 class="mb-3"><i class="fas fa-list text-info"></i> Последние сокращения (10)</h3>
    <div class="table-responsive">
        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>ID</th><th>Оригинал</th><th>Код</th><th>Ссылка</th><th>Клики</th><th>Создано</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var link in Model.Links)
                {
                    <tr>
                        <td><code>@link.Id</code></td>
                        <td title="@link.OriginalUrl">@link.OriginalUrl.Substring(0, Math.Min(40, link.OriginalUrl.Length))...</td>
                        <td><code>@link.ShortCode</code></td>
                        <td><a href="/@link.ShortCode" target="_blank">/@link.ShortCode</a></td>
                        <td><span class="badge bg-primary">@link.ClickCount</span></td>
                        <td>@link.CreatedAt.ToString("dd.MM HH:mm")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-warning">✏️ Edit</button>
                            <button class="btn btn-sm btn-outline-danger" onclick="confirmDelete(@link.Id)">🗑️ Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => alert('Скопировано!'));
}
function confirmDelete(id) {
    if (confirm('Удалить ссылку?')) {
        // AJAX delete
    }
}
</script>
