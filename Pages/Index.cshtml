@page
@model IndexModel
<h1>🔗 URL Shortener</h1>

<form method="post">
    <input asp-for="OriginalUrl" placeholder="https://example.com" />
    <button type="submit">Сократить</button>
</form>

@if (!string.IsNullOrEmpty(Model.ShortUrl))
{
    <p>Короткая ссылка: <a href="@Model.ShortUrl">@Model.ShortUrl</a></p>
}

<h3>Последние ссылки:</h3>
<table>
    @foreach (var link in Model.Links)
    {
        <tr>
            <td>@link.ShortCode</td>
            <td>@link.OriginalUrl</td>
            <td>@link.ClickCount</td>
        </tr>
    }
</table>
